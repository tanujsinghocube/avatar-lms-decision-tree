{\n  "decisionTree": [\n    {\n      "id": 1,\n      "scenario": "Customer has an active license that will expire in less than 30 days.",\n      "decisionPath": [\n        "Send renewal notification to the customer.",\n        "Provide early renewal discounts if applicable.",\n        "Encourage the customer to renew now to avoid interruption."\n      ],\n      "outcome": "Customer renews their license before expiration.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 2,\n      "scenario": "Customer has an active license that will expire in 31-60 days.",\n      "decisionPath": [\n        "Send reminder email about the upcoming expiration.",\n        "Inform them about the benefits of renewing early.",\n        "Ask if they need further information or assistance."\n      ],\n      "outcome": "Customer expresses intent to renew but needs more information.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 3,\n      "scenario": "Customer's license has expired but is still within the grace period.",\n      "decisionPath": [\n        "Notify customer about the expired license and grace period.",\n        "Offer a special renewal rate during the grace period.",\n        "Promote the benefits of continuing service uninterrupted."\n      ],\n      "outcome": "Customer renews taking advantage of the grace period offer.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 4,\n      "scenario": "Customer's license has expired and is outside the grace period.",\n      "decisionPath": [\n        "Contact customer to discuss service interruption.",\n        "Explain the need to renew for continued access.",\n        "Provide options for renewal at the standard rate."\n      ],\n      "outcome": "Customer renews after understanding the situation.\n      ",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 5,\n      "scenario": "Customer is considering alternative LMS solutions.",\n      "decisionPath": [\n        "Schedule a call to address customer concerns.",\n        "Discuss specific needs and how Ocube meets them.",\n        "Offer trial extensions or demos of new features."\n      ],\n      "outcome": "Customer decides to continue with Ocube based on support and features.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 6,\n      "scenario": "Customer is satisfied and wants to renew without any discounts.",\n      "decisionPath": [\n        "Confirm renewal details with the customer.",\n        "Process the renewal quickly to ensure seamless access.",\n        "Send confirmation once the renewal is completed."\n      ],\n      "outcome": "Customer successfully renews their license with no issues.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 7,\n      "scenario": "Customer has questions about new pricing or features.",\n      "decisionPath": [\n        "Provide detailed information on changes.",\n        "Highlight benefits of new features introduced.",\n        "Clarify any doubts they have regarding pricing."\n      ],\n      "outcome": "Customer decides to renew after clarification.\n      ",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 8,\n      "scenario": "Customer did not respond to renewal offers.",\n      "decisionPath": [\n        "Send a last reminder before the expiration date.",\n        "Ask if they need to discuss their options directly.",\n        "Provide an easy link for immediate renewal."\n      ],\n      "outcome": "Customer renews after receiving the last reminder.\n      ",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 9,\n      "scenario": "Customer's organization policy requires multiple approvals for renewal.",\n      "decisionPath": [\n        "Communicate the need for timely renewal to the customer.",\n        "Assist them in getting the necessary approvals."\n      ],\n      "outcome": "Renewal is delayed but eventually processed once approvals received.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    },\n    {\n      "id": 10,\n      "scenario": "Customer expresses dissatisfaction with service quality.",\n      "decisionPath": [\n        "Schedule a feedback session with the customer.",\n        "Address any issues and offer solutions or improvements.",\n        "After addressing concerns, offer renewal incentives."\n      ],\n      "outcome": "Customer feels valued and chooses to renew after improvements are made.",\n      "metadata": {\n        "createdBy": "tanujsinghocube",\n        "createdOn": "2026-03-09 21:59:50",\n        "lastUpdated": "2026-03-09 21:59:50"\n      }\n    }\n  ]\n}