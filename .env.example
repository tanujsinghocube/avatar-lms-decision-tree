# Environment Configuration Example

# Zoho CRM API Credentials
ZOHO_CLIENT_ID="your_zoho_client_id"
ZOHO_CLIENT_SECRET="your_zoho_client_secret"
ZOHO_REFRESH_TOKEN="your_zoho_refresh_token"

# ZIMYO Credentials
ZIMYO_API_KEY="your_zimyo_api_key"
ZIMYO_API_SECRET="your_zimyo_api_secret"

# Multicomm API Credentials
MULTICOMM_API_URL="your_multicomm_api_url"
MULTICOMM_API_KEY="your_multicomm_api_key"

# MongoDB Connection String
MONGODB_CONNECTION_STRING="your_mongodb_connection_string"

# Other Settings
# Add any other relevant settings below
# EXAMPLE_SETTING="example_value"